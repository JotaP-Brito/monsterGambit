{
  "manifest_version": 3,
  "name": "MonsterGambit Live",
  "version": "1.1",
  "description": "Show Stockfish's best move on chess.com",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*.chess.com/*", "http://127.0.0.1:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}